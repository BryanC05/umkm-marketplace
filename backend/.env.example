# Server Configuration
PORT=5000
MONGODB_URI=mongodb://localhost:27017/msme_marketplace
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
NODE_ENV=development

# AI Services
LOGO_MODEL=flux
POLLINATIONS_API_KEY=your-pollinations-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key
HUGGINGFACE_MODEL=black-forest-labs/FLUX.1-dev
GROQ_API_KEY=your-groq-api-key

# Image Enhancement
CLAID_API_KEY=your-claid-api-key
CLAID_BASE_URL=https://api.claid.ai/v1
CLAID_TIMEOUT_SECONDS=45
PRODUCT_IMAGE_MAX_SIZE_MB=5
PRODUCT_IMAGE_MAX_COUNT=4
PRODUCT_ENHANCE_DAILY_LIMIT=20

# Maps & Location
GOOGLEMAP_API_KEY=your-google-maps-api-key

# n8n Webhook (for automation)
N8N_WEBHOOK_URL=https://your-n8n-app.railway.app/webhook/your-webhook-url

# Instagram API (for n8n automation - platform level posting)
# These are used when the platform posts on behalf of connected accounts
IG_ACCESS_TOKEN=your-instagram-access-token
IG_ACCOUNT_ID=your-instagram-business-account-id

# Instagram OAuth (for user-connected accounts)
# Required for users to connect their own Instagram accounts
# Get these from https://developers.facebook.com/ after creating an app
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_REDIRECT_URI=https://your-domain.com/api/users/instagram/callback
